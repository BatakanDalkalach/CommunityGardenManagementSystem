@model IEnumerable<WebApplication1.Models.MaintenanceRequest>
@{
    ViewData["Title"] = "Maintenance Requests";
}

<article class="cgms-list-container">
    <style>
        .cgms-list-container { background: linear-gradient(135deg, #e0f2fe, #fff); padding: 2.5rem 1rem; min-height: 100vh; }
        .cgms-list-card { max-width: 1000px; margin: 0 auto; background: white; border-radius: 1.2rem; overflow: hidden; box-shadow: 0 6px 24px rgba(0,0,0,0.1); }
        .cgms-list-header { background: #0369a1; padding: 2.5rem; color: white; }
        .cgms-list-icon { font-size: 3rem; margin-bottom: 0.6rem; }
        .cgms-list-heading { margin: 0; font-size: 2rem; font-weight: 900; }
        .cgms-list-subhead { margin: 0.5rem 0 0; opacity: 0.88; }
        .cgms-list-body { padding: 2rem; }
        .status-pending { background: #fef9c3; color: #854d0e; }
        .status-inprogress { background: #dbeafe; color: #1e40af; }
        .status-completed { background: #dcfce7; color: #166534; }
        .status-badge { padding: 0.35rem 0.85rem; border-radius: 2rem; font-weight: 700; font-size: 0.85rem; }
    </style>

    <div class="container">
        <div class="cgms-list-card">
            <header class="cgms-list-header">
                <div class="cgms-list-icon">🔧</div>
                <h1 class="cgms-list-heading">Maintenance Requests</h1>
                <p class="cgms-list-subhead">Track and manage plot maintenance requests</p>
            </header>

            <div class="cgms-list-body">
                @if (TempData["SuccessMsg"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        @TempData["SuccessMsg"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <div class="d-flex justify-content-end mb-3">
                    <a asp-action="Create" class="btn btn-primary">+ New Request</a>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Plot</th>
                                <th>Description</th>
                                <th>Request Date</th>
                                <th>Status</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                var statusClass = item.Status switch
                                {
                                    WebApplication1.Models.MaintenanceStatus.Pending => "status-pending",
                                    WebApplication1.Models.MaintenanceStatus.InProgress => "status-inprogress",
                                    WebApplication1.Models.MaintenanceStatus.Completed => "status-completed",
                                    _ => ""
                                };
                                <tr>
                                    <td class="text-muted small">@item.Id</td>
                                    <td><span class="fw-bold">@item.Plot?.PlotDesignation</span></td>
                                    <td class="text-truncate" style="max-width: 260px;">@item.Description</td>
                                    <td class="text-muted small">@item.RequestDate.ToString("MMM d, yyyy")</td>
                                    <td><span class="status-badge @statusClass">@item.Status</span></td>
                                    <td class="text-end">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">View</a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                                    </td>
                                </tr>
                            }
                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-4">No maintenance requests yet.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</article>
