@model WebApplication1.Models.MaintenanceRequest
@{
    ViewData["Title"] = "Request Details";
    var statusColor = Model.Status switch
    {
        WebApplication1.Models.MaintenanceStatus.Pending => "#854d0e",
        WebApplication1.Models.MaintenanceStatus.InProgress => "#1e40af",
        WebApplication1.Models.MaintenanceStatus.Completed => "#166534",
        _ => "#374151"
    };
    var statusBg = Model.Status switch
    {
        WebApplication1.Models.MaintenanceStatus.Pending => "#fef9c3",
        WebApplication1.Models.MaintenanceStatus.InProgress => "#dbeafe",
        WebApplication1.Models.MaintenanceStatus.Completed => "#dcfce7",
        _ => "#f3f4f6"
    };
}

<article class="cgms-detail-container">
    <style>
        .cgms-detail-container { background: #f3f4f6; padding: 2.5rem 1rem; min-height: 100vh; }
        .cgms-detail-card { max-width: 820px; margin: 0 auto; background: white; border-radius: 1.2rem; overflow: hidden; box-shadow: 0 6px 24px rgba(0,0,0,0.12); }
        .cgms-detail-masthead { background: #0369a1; padding: 2.5rem; color: white; }
        .cgms-detail-plot { font-size: 3.5rem; font-weight: 900; margin: 0 0 0.6rem; }
        .cgms-detail-badge { display: inline-block; padding: 0.5rem 1.4rem; border-radius: 2rem; font-weight: 700; background: @statusBg; color: @statusColor; }
        .cgms-detail-body { padding: 2.5rem; }
        .cgms-info-panel { border: 2px solid #e5e7eb; border-radius: 1rem; padding: 2rem; margin-bottom: 2rem; }
        .cgms-info-title { font-size: 1.4rem; font-weight: 800; margin-bottom: 1.4rem; color: #111827; }
        .cgms-info-cell { display: flex; justify-content: space-between; padding: 0.8rem 0; border-bottom: 1px solid #e5e7eb; }
        .cgms-info-cell:last-child { border-bottom: none; }
        .cgms-info-key { color: #6b7280; font-weight: 600; }
        .cgms-info-val { font-weight: 700; color: #111827; text-align: right; max-width: 65%; }
        .cgms-description-box { background: #f8fafc; border-left: 4px solid #0369a1; border-radius: 0.5rem; padding: 1.4rem; margin-bottom: 2rem; white-space: pre-wrap; line-height: 1.7; }
        .cgms-button-dock { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; padding-top: 2rem; border-top: 2px solid #e5e7eb; }
        .cgms-dock-btn { padding: 1rem; text-align: center; border-radius: 0.8rem; text-decoration: none; font-weight: 800; }
        .cgms-dock-back { background: #9ca3af; color: white; }
        .cgms-dock-back:hover { background: #6b7280; color: white; }
        .cgms-dock-edit { background: #fbbf24; color: #78350f; }
        .cgms-dock-edit:hover { background: #f59e0b; color: white; }
        .cgms-dock-remove { background: #ef4444; color: white; }
        .cgms-dock-remove:hover { background: #dc2626; color: white; }
    </style>

    <div class="container">
        <div class="cgms-detail-card">
            <header class="cgms-detail-masthead">
                <div class="cgms-detail-plot">🔧 Plot @Model.Plot?.PlotDesignation</div>
                <div class="cgms-detail-badge">@Model.Status</div>
            </header>

            <div class="cgms-detail-body">
                <section class="cgms-info-panel">
                    <h2 class="cgms-info-title">📋 Request Details</h2>
                    <div class="cgms-info-cell">
                        <span class="cgms-info-key">Request ID</span>
                        <span class="cgms-info-val">#@Model.Id</span>
                    </div>
                    <div class="cgms-info-cell">
                        <span class="cgms-info-key">Plot</span>
                        <span class="cgms-info-val">@Model.Plot?.PlotDesignation</span>
                    </div>
                    <div class="cgms-info-cell">
                        <span class="cgms-info-key">Request Date</span>
                        <span class="cgms-info-val">@Model.RequestDate.ToString("dddd, MMMM d, yyyy")</span>
                    </div>
                    <div class="cgms-info-cell">
                        <span class="cgms-info-key">Status</span>
                        <span class="cgms-info-val" style="color: @statusColor;">@Model.Status</span>
                    </div>
                </section>

                <section>
                    <h2 style="font-size: 1.2rem; font-weight: 800; margin-bottom: 1rem; color: #111827;">📝 Description</h2>
                    <div class="cgms-description-box">@Model.Description</div>
                </section>

                <nav class="cgms-button-dock">
                    <a asp-action="Index" class="cgms-dock-btn cgms-dock-back">← Back</a>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="cgms-dock-btn cgms-dock-edit">✏️ Edit</a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="cgms-dock-btn cgms-dock-remove">🗑️ Delete</a>
                </nav>
            </div>
        </div>
    </div>
</article>
