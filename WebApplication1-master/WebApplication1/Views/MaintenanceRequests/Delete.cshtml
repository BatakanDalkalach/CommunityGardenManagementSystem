@model WebApplication1.Models.MaintenanceRequest
@{
    ViewData["Title"] = "Delete Maintenance Request";
}

<div style="max-width: 640px; margin: 0 auto;">
    <div class="card border-danger shadow-sm">
        <div class="card-header bg-danger text-white fw-bold">
            🗑️ Confirm Deletion
        </div>
        <div class="card-body">
            <p class="text-muted mb-3">Are you sure you want to permanently delete this maintenance request? This action cannot be undone.</p>
            <dl class="row">
                <dt class="col-sm-4 text-muted">Plot</dt>
                <dd class="col-sm-8 fw-semibold">@Model.Plot?.PlotDesignation</dd>

                <dt class="col-sm-4 text-muted">Description</dt>
                <dd class="col-sm-8">@Model.Description</dd>

                <dt class="col-sm-4 text-muted">Request Date</dt>
                <dd class="col-sm-8">@Model.RequestDate.ToString("MMM d, yyyy")</dd>

                <dt class="col-sm-4 text-muted">Status</dt>
                <dd class="col-sm-8">
                    <span class="badge @(Model.Status == WebApplication1.Models.MaintenanceStatus.Completed ? "bg-success" : Model.Status == WebApplication1.Models.MaintenanceStatus.InProgress ? "bg-primary" : "bg-warning text-dark")">
                        @Model.Status
                    </span>
                </dd>
            </dl>
        </div>
        <div class="card-footer d-flex gap-2 justify-content-end">
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            <form asp-action="Delete" method="post" style="display:inline">
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn btn-danger">Yes, Delete</button>
            </form>
        </div>
    </div>
</div>
