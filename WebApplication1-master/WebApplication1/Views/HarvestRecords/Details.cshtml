@model WebApplication1.Models.HarvestRecord
@{
    ViewData["Title"] = "Harvest Details";
    var stars = new string('★', Model.QualityScore) + new string('☆', 5 - Model.QualityScore);
}

<article class="cgms-detail-container">
    <style>
        .cgms-detail-container { background: linear-gradient(135deg, #dcfce7, #fff); padding: 2.5rem 1rem; min-height: 100vh; }
        .cgms-detail-card { max-width: 820px; margin: 0 auto; background: white; border-radius: 1.2rem; overflow: hidden; box-shadow: 0 8px 32px rgba(0,0,0,0.1); }
        .cgms-detail-header { background: #15803d; padding: 2.5rem; text-align: center; color: white; }
        .cgms-detail-icon { font-size: 3.5rem; margin-bottom: 0.6rem; }
        .cgms-detail-title { margin: 0; font-size: 2.1rem; font-weight: 900; }
        .cgms-detail-sub { margin: 0.4rem 0 0; opacity: 0.85; font-size: 1.05rem; }
        .cgms-detail-body { padding: 2.4rem; }
        .cgms-metrics { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 2rem; }
        .cgms-metric { background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 0.8rem; padding: 1.2rem; text-align: center; }
        .cgms-metric-value { font-size: 1.6rem; font-weight: 900; color: #15803d; }
        .cgms-metric-label { font-size: 0.8rem; color: #6b7280; text-transform: uppercase; letter-spacing: 0.05em; margin-top: 0.2rem; }
        .cgms-info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; margin-bottom: 1.5rem; }
        .cgms-info-item { border-left: 3px solid #15803d; padding: 0.8rem 1rem; background: #f9fafb; border-radius: 0 0.5rem 0.5rem 0; }
        .cgms-info-label { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.06em; color: #9ca3af; font-weight: 700; }
        .cgms-info-value { font-size: 1rem; font-weight: 600; color: #111827; margin-top: 0.2rem; }
        .cgms-notes-box { background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 0.8rem; padding: 1.2rem; margin-top: 0.5rem; }
        .organic-chip { display: inline-block; background: #dcfce7; color: #15803d; border: 1px solid #86efac; padding: 0.3rem 0.85rem; border-radius: 2rem; font-weight: 700; font-size: 0.88rem; }
        .quality-stars { color: #f59e0b; font-size: 1.4rem; letter-spacing: 1px; }
        .cgms-action-bar { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 2rem; padding-top: 1.5rem; border-top: 2px solid #e5e7eb; }
    </style>

    <div class="container">
        <div class="cgms-detail-card">
            <header class="cgms-detail-header">
                <div class="cgms-detail-icon">🌾</div>
                <h1 class="cgms-detail-title">@Model.CropName</h1>
                <p class="cgms-detail-sub">Harvest Record #@Model.RecordId</p>
            </header>

            <div class="cgms-detail-body">
                <div class="cgms-metrics">
                    <div class="cgms-metric">
                        <div class="cgms-metric-value">@Model.QuantityKilograms.ToString("F1")</div>
                        <div class="cgms-metric-label">Kilograms</div>
                    </div>
                    <div class="cgms-metric">
                        <div class="cgms-metric-value quality-stars">@stars</div>
                        <div class="cgms-metric-label">Quality (@Model.QualityScore/5)</div>
                    </div>
                    <div class="cgms-metric">
                        <div class="cgms-metric-value">@Model.CollectionDate.ToString("MMM d")</div>
                        <div class="cgms-metric-label">@Model.CollectionDate.Year</div>
                    </div>
                </div>

                <div class="cgms-info-grid">
                    <div class="cgms-info-item">
                        <div class="cgms-info-label">Garden Plot</div>
                        <div class="cgms-info-value">@(Model.SourcePlot?.PlotDesignation ?? "—")</div>
                    </div>
                    <div class="cgms-info-item">
                        <div class="cgms-info-label">Harvester</div>
                        <div class="cgms-info-value">@(Model.Harvester?.FullLegalName ?? "—")</div>
                    </div>
                    <div class="cgms-info-item">
                        <div class="cgms-info-label">Collection Date</div>
                        <div class="cgms-info-value">@Model.CollectionDate.ToString("dddd, MMMM d, yyyy")</div>
                    </div>
                    <div class="cgms-info-item">
                        <div class="cgms-info-label">Certification</div>
                        <div class="cgms-info-value">
                            @if (Model.IsOrganicCertified)
                            {
                                <span class="organic-chip">✓ Organic Certified</span>
                            }
                            else
                            {
                                <span class="text-muted">Conventional</span>
                            }
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.HarvestNotes))
                {
                    <div>
                        <div class="fw-bold mb-1" style="color:#111827;">Observations</div>
                        <div class="cgms-notes-box text-muted">@Model.HarvestNotes</div>
                    </div>
                }

                <div class="cgms-action-bar">
                    <a asp-action="Index" class="btn btn-outline-secondary">← Back to List</a>
                    @if (User.Identity!.IsAuthenticated)
                    {
                        <a asp-action="Edit" asp-route-id="@Model.RecordId" class="btn btn-warning">Edit Record</a>
                        <a asp-action="Delete" asp-route-id="@Model.RecordId" class="btn btn-outline-danger ms-auto">Delete</a>
                    }
                </div>
            </div>
        </div>
    </div>
</article>
