@model WebApplication1.Models.Announcement
@{
    ViewData["Title"] = "Delete Announcement";
}

<div style="max-width: 640px; margin: 0 auto;">
    <div class="card border-danger shadow-sm">
        <div class="card-header bg-danger text-white fw-bold">
            🗑️ Confirm Deletion
        </div>
        <div class="card-body">
            <p class="text-muted mb-3">Are you sure you want to permanently delete this announcement? This action cannot be undone.</p>
            <dl class="row">
                <dt class="col-sm-4 text-muted">Title</dt>
                <dd class="col-sm-8 fw-semibold">@Model.Title</dd>

                <dt class="col-sm-4 text-muted">Status</dt>
                <dd class="col-sm-8">
                    @if (Model.IsPublished)
                    {
                        <span class="badge bg-success">Published</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Draft</span>
                    }
                </dd>

                <dt class="col-sm-4 text-muted">Created</dt>
                <dd class="col-sm-8">@Model.CreatedAt.ToLocalTime().ToString("MMM d, yyyy HH:mm")</dd>
            </dl>
        </div>
        <div class="card-footer d-flex gap-2 justify-content-end">
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            <form asp-action="Delete" method="post" style="display:inline">
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn btn-danger">Yes, Delete</button>
            </form>
        </div>
    </div>
</div>
