@model WebApplication1.Models.Announcement
@{
    ViewData["Title"] = "Create Announcement";
}

<article class="cgms-form-container">
    <style>
        .cgms-form-container { background: linear-gradient(135deg, #d1fae5, #fff); padding: 2.5rem 1rem; min-height: 80vh; }
        .cgms-form-card { max-width: 760px; margin: 0 auto; background: white; border-radius: 1.2rem; overflow: hidden; box-shadow: 0 8px 32px rgba(0,0,0,0.1); }
        .cgms-form-header { background: #1e3a2f; padding: 2.2rem; text-align: center; color: white; }
        .cgms-form-heading { margin: 0; font-size: 1.8rem; font-weight: 900; }
        .cgms-form-subhead { margin: 0.5rem 0 0; opacity: 0.85; }
        .cgms-form-main { padding: 2.4rem; }
        .cgms-input-group { margin-bottom: 1.6rem; }
        .cgms-label-text { display: block; font-weight: 700; margin-bottom: 0.5rem; color: #111827; }
        .cgms-input-field { width: 100%; padding: 0.9rem; border: 2px solid #d1d5db; border-radius: 0.7rem; font-size: 1rem; }
        .cgms-input-field:focus { outline: none; border-color: #1e3a2f; box-shadow: 0 0 0 3px rgba(30,58,47,0.1); }
        .cgms-checkbox-wrap { background: #f3f4f6; padding: 1.2rem; border-radius: 0.7rem; display: flex; align-items: center; gap: 0.9rem; }
        .cgms-checkbox-input { width: 22px; height: 22px; }
        .cgms-checkbox-label { margin: 0; font-weight: 600; }
        .cgms-button-group { display: grid; grid-template-columns: 1fr 2fr; gap: 1rem; margin-top: 2rem; padding-top: 1.8rem; border-top: 2px solid #e5e7eb; }
        .cgms-btn { padding: 1rem; text-align: center; border-radius: 0.7rem; font-weight: 800; font-size: 1rem; cursor: pointer; text-decoration: none; display: block; }
        .cgms-btn-cancel { background: #9ca3af; color: white; }
        .cgms-btn-cancel:hover { background: #6b7280; color: white; }
        .cgms-btn-submit { background: #1e3a2f; color: white; border: none; }
        .cgms-btn-submit:hover { background: #2d5a40; }
    </style>

    <div class="container">
        <div class="cgms-form-card">
            <header class="cgms-form-header">
                <div style="font-size:2.5rem;margin-bottom:0.6rem;">📢</div>
                <h1 class="cgms-form-heading">New Announcement</h1>
                <p class="cgms-form-subhead">Fill in the details below to post an announcement</p>
            </header>

            <form asp-action="Create" method="post" class="cgms-form-main">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="cgms-input-group">
                    <label asp-for="Title" class="cgms-label-text"></label>
                    <input asp-for="Title" class="cgms-input-field" placeholder="Enter announcement title..." />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>

                <div class="cgms-input-group">
                    <label asp-for="Content" class="cgms-label-text"></label>
                    <textarea asp-for="Content" class="cgms-input-field" rows="6" placeholder="Write the announcement content here..."></textarea>
                    <span asp-validation-for="Content" class="text-danger small"></span>
                </div>

                <div class="cgms-input-group">
                    <div class="cgms-checkbox-wrap">
                        <input asp-for="IsPublished" type="checkbox" class="cgms-checkbox-input" />
                        <label asp-for="IsPublished" class="cgms-checkbox-label">Publish immediately (visible to all members)</label>
                    </div>
                </div>

                <nav class="cgms-button-group">
                    <a asp-action="Index" class="cgms-btn cgms-btn-cancel">Cancel</a>
                    <button type="submit" class="cgms-btn cgms-btn-submit">📢 Create Announcement</button>
                </nav>
            </form>
        </div>
    </div>
</article>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
