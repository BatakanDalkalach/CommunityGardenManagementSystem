@model IEnumerable<WebApplication1.Models.Announcement>
@{
    ViewData["Title"] = "Announcements";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h6 class="text-muted mb-0">Manage public announcements visible to garden members.</h6>
    <a asp-action="Create" class="btn btn-success btn-sm">+ New Announcement</a>
</div>

@if (TempData["SuccessMsg"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMsg"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Title</th>
                    <th>Created</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-muted small">@item.Id</td>
                        <td class="fw-semibold">@item.Title</td>
                        <td class="text-muted small">@item.CreatedAt.ToLocalTime().ToString("MMM d, yyyy HH:mm")</td>
                        <td>
                            @if (item.IsPublished)
                            {
                                <span class="badge bg-success">Published</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Draft</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">View</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">No announcements yet. Create one above.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
