@using WebApplication1.Models
@model IList<ApplicationUser>
@{
    ViewData["Title"] = "System Users";
    var userRoles = ViewBag.UserRoles as Dictionary<string, IList<string>>;
    var currentUserId = UserManager?.GetUserId(User) ?? string.Empty;
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-header bg-white fw-semibold">All System Users</div>
    <div class="card-body p-0">
        <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Confirmed</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    var roles = userRoles != null && userRoles.ContainsKey(user.Id)
                        ? userRoles[user.Id]
                        : new List<string>();
                    var isAdmin = roles.Contains("Admin");
                    var isSelf = user.Id == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                    <tr>
                        <td>@(user.FullName ?? "—")</td>
                        <td>@user.Email</td>
                        <td>
                            @foreach (var role in roles)
                            {
                                <span class="badge @(role == "Admin" ? "bg-danger" : "bg-secondary") me-1">@role</span>
                            }
                        </td>
                        <td>
                            @if (user.EmailConfirmed)
                            {
                                <span class="text-success">✓</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>
                            @if (isSelf)
                            {
                                <span class="text-muted small">—</span>
                            }
                            else
                            {
                                <form asp-action="ToggleRole" asp-controller="Dashboard" asp-area="Admin" method="post" class="d-inline">
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="btn btn-sm @(isAdmin ? "btn-outline-secondary" : "btn-outline-danger")"
                                            onclick="return confirm('@(isAdmin ? $"Demote {user.Email} to User?" : $"Promote {user.Email} to Admin?")')">
                                        @(isAdmin ? "Demote to User" : "Promote to Admin")
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    </div>
</div>
